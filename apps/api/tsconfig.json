{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "resolvePackageJsonExports": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2023",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "jsx": "react-jsx",
        "paths": {
            "@portals": ["src/modules/portal/crm/portals"],
            "@portals/*": ["src/modules/portal/crm/portals/*"],
            "@modules/*": ["src/modules/*"],
            "@modules": ["src/modules"],
            "@shared/*": ["src/modules/shared/*"],
            "@common/*": ["src/common/*"],
            "@users": ["src/modules/users"],
            "@users/*": ["src/modules/users/*"],
            "@auth": ["src/modules/portal/auth"],
            "@auth/*": ["src/modules/portal/auth/*"],
            "@employees": ["src/modules/portal/crm/employees"],
            "@employees/*": ["src/modules/portal/crm/employees/*"],
            "@members": ["src/modules/portal/crm/members"],
            "@members/*": ["src/modules/portal/crm/members/*"],
            "@storage": ["src/modules/storage"],
            "@storage/*": ["src/modules/storage/*"],
            "@encryption": ["src/modules/encryption"],
            "@encryption/*": ["src/modules/encryption/*"],
            "@catalog": ["src/modules/portal/crm/catalog"],
            "@catalog/*": ["src/modules/portal/crm/catalog/*"],
            "@orders": ["src/modules/portal/crm/orders"],
            "@orders/*": ["src/modules/portal/crm/orders/*"],
            "@finance": ["src/modules/portal/crm/finance"],
            "@finance/*": ["src/modules/portal/crm/finance/*"],
            "@qr-codes": ["src/modules/portal/crm/qr-codes"],
            "@qr-codes/*": ["src/modules/portal/crm/qr-codes/*"],
            "@presence": ["src/modules/portal/crm/presence"],
            "@presence/*": ["src/modules/portal/crm/presence/*"],
            "@mail": ["src/modules/mail"],
            "@mail/*": ["src/modules/mail/*"],
            "@entity-fields": ["src/modules/portal/crm/entity-fields"],
            "@entity-fields/*": ["src/modules/portal/crm/entity-fields/*"],
            "@core/*": ["src/core/*"],
            "@platform/*": ["src/modules/platform/*"],
            "@crm": ["src/modules/crm/crm.module"]
        },
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "noFallthroughCasesInSwitch": false
    }
}
