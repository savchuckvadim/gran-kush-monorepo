{
    "name": "api",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "fix": "pnpm run lint --fix",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" --ignore-path ../../.prettierignore",
        "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" --ignore-path ../../.prettierignore",
        "start": "nest start",
        "dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "onstart:prod:with-migrations": "pnpm prisma:migrate:deploy && pnpm prisma:seed:admin",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "prisma:seed": "prisma db seed",
        "prisma:seed:admin": "ts-node prisma/seed-admin.ts",
        "postinstall": "prisma generate"
    },
    "prisma": {
        "seed": "ts-node prisma/seed-admin.ts"
    },
    "dependencies": {
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/swagger": "^11.2.6",
        "@prisma/adapter-pg": "^7.4.0",
        "@prisma/client": "^7.4.0",
        "@react-email/components": "1.0.7",
        "@react-email/font": "0.0.10",
        "@react-email/html": "0.0.12",
        "@react-email/img": "0.0.12",
        "@react-email/link": "0.0.13",
        "add": "^2.0.6",
        "bcrypt": "^6.0.0",
        "bull": "^4.16.5",
        "bullmq": "^5.69.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "cookie-parser": "^1.4.7",
        "express-session": "^1.19.0",
        "ioredis": "^5.9.2",
        "nodemailer": "^8.0.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.18.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@react-email/preview-server": "5.2.8",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/express-session": "^1.18.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.10.7",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^11.0.0",
        "@workspace/prettier-config": "workspace:*",
        "dotenv": "^17.2.4",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^16.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.4.2",
        "prisma": "^7.4.0",
        "react-email": "5.2.8",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
